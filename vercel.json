{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "collabio_client/dist",
  "functions": {
    "api/[...path].ts": {
      "includeFiles": ["collabio_backend/src/**"]
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
