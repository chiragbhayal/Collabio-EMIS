{
  "version": 2,
  "buildCommand": "",
  "functions": {
    "api/[...path].ts": {
      "includeFiles": "src/**",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/[...path].ts"
    },
    {
      "src": "/(.*)",
      "dest": "api/[...path].ts"
    }
  ]
}
